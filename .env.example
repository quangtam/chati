# ── Telegram ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-here
ALLOWED_USER_IDS=123456789

# ── CLI Provider ─────────────────────────────────────────────────
# Options: kiro, claude, gemini, codex
CLI_PROVIDER=kiro

# CLI binary path (auto-detected from PATH if empty)
# CLI_PATH=/usr/local/bin/kiro-cli

# API key — or use provider-specific vars below
# CLI_API_KEY=your-api-key

# Extra CLI arguments (space-separated)
# CLI_EXTRA_ARGS=--verbose

# ── Provider-specific API keys ───────────────────────────────────
# All CLIs auth via local login session by default.
# Only set API keys here for headless/SSH machines without browser access.
# KIRO_API_KEY=your-kiro-api-key
# ANTHROPIC_API_KEY=your-anthropic-key
# GEMINI_API_KEY=your-gemini-key
# OPENAI_API_KEY=your-openai-key

# ── Project ──────────────────────────────────────────────────────
PROJECT_DIR=/path/to/your/project

# ── Options ──────────────────────────────────────────────────────
CLI_TIMEOUT=300
CLI_TRUST_ALL_TOOLS=true
LOG_LEVEL=INFO

# ── Voice Features (Growth) ──────────────────────────────────────
# Voice works WITHOUT an OpenAI key using free local backends:
#   - Transcription: faster-whisper (local CPU, no internet needed)
#   - TTS: edge-tts (Microsoft Edge TTS, free, needs internet)
#
# Set OPENAI_API_KEY to upgrade to higher-quality cloud backends.
#
OPENAI_API_KEY=sk-your-openai-key-here
#
# OpenAI cloud settings (only used when OPENAI_API_KEY is set):
WHISPER_MODEL=gpt-4o-mini-transcribe    # or gpt-4o-transcribe for higher quality
WHISPER_TIMEOUT=30
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=echo                         # alloy, ash, coral, echo, fable, nova, onyx, sage, shimmer
TTS_SPEED=1.5                          # 0.25–4.0 (1.0=normal, 1.5=faster, 2.0=fast)
TTS_TIMEOUT=30
#
# Local backend settings (used when OPENAI_API_KEY is NOT set):
# WHISPER_LOCAL_MODEL=base                # tiny (75MB/fastest) | base (140MB) | small (460MB/best)
# TTS_LOCAL_VOICE=vi-VN-HoaiMyNeural     # edge-tts voice (vi-VN-NamMinhNeural for male)
# TTS_LOCAL_RATE=+30%                     # +0%=normal, +30%=faster, +50%=fast
#
# Voice output is off by default — user enables per-thread with /voice command:
# VOICE_OUTPUT_ENABLED=false
# Auto-send voice transcription without confirm keyboard:
# VOICE_AUTO_SEND=false
