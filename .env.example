# ── Telegram ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-here
ALLOWED_USER_IDS=123456789

# ── CLI Provider ─────────────────────────────────────────────────
# Options: kiro, claude, gemini, codex
CLI_PROVIDER=kiro

# CLI binary path (auto-detected from PATH if empty)
# CLI_PATH=/usr/local/bin/kiro-cli

# API key — or use provider-specific vars below
# CLI_API_KEY=your-api-key

# Extra CLI arguments (space-separated)
# CLI_EXTRA_ARGS=--verbose

# ── Provider-specific API keys ───────────────────────────────────
# Most CLIs auth via local login (claude login, gemini auth, codex login).
# Only set API keys here if the CLI requires them or you prefer key-based auth.
KIRO_API_KEY=your-kiro-api-key
# ANTHROPIC_API_KEY=your-anthropic-key    # optional — claude prefers local login
# GEMINI_API_KEY=your-gemini-key          # optional — gemini prefers local login
# OPENAI_API_KEY=your-openai-key          # optional — codex prefers local login

# ── Project ──────────────────────────────────────────────────────
PROJECT_DIR=/path/to/your/project

# ── Options ──────────────────────────────────────────────────────
CLI_TIMEOUT=300
CLI_TRUST_ALL_TOOLS=true
LOG_LEVEL=INFO
